{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "website",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2025-10-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "website-assets"
    }
  ]
}